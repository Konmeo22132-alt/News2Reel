# ─── AI API ───────────────────────────────────────────────────────────────────────────────
# Beeknoee API Key (lấy tại platform.beeknoee.com → API Keys)
# Format: sk-bee-...
# Provider: platform.beeknoee.com | Model: openai/gpt-oss-120b

# ─── Database ───────────────────────────────────────────────────────────────────────────────
# MongoDB connection string
# Local:  mongodb://localhost:27017/autovideo
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/autovideo
MONGODB_URI="mongodb://localhost:27017/autovideo"

# ─── Authentication ────────────────────────────────────────────────────────────────────────────
# Admin panel password (change this!)
ADMIN_PASSWORD="admin"

# ─── Cron Auto-Generation ─────────────────────────────────────────────────────────────────────
# Secret token để bảo vệ endpoint POST /api/cron/auto-generate
# Set bất kỳ chuỗi ngẫu nhiên dài ≥ 32 ký tự
# Trigger từ crontab: curl -X POST http://localhost:3000/api/cron/auto-generate -H "Authorization: Bearer YOUR_SECRET"
# CRON_SECRET="your-random-secret-here"

# ─── FFmpeg Path Override ─────────────────────────────────────────────────────────────────────
# Nếu ffmpeg không có trong PATH, set đường dẫn tuyệt đối ở đây
# Linux/Ubuntu: FFMPEG_PATH="/usr/bin/ffmpeg"
# Windows:      FFMPEG_PATH="C:/ffmpeg/bin/ffmpeg.exe"
# FFMPEG_PATH=""

